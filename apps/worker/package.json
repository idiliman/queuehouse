{
  "name": "@queuehouse/worker",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/worker.ts",
    "start": "bun run src/worker.ts",
    "build": "bun build src/worker.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/context-async-hooks": "1.30.1",
    "@opentelemetry/core": "1.30.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.52.1",
    "@opentelemetry/resources": "1.30.1",
    "@opentelemetry/sdk-trace-base": "1.30.1",
    "@queuehouse/bull-ops": "workspace:*",
    "@queuehouse/core": "workspace:*",
    "@queuehouse/db": "workspace:*",
    "bullmq": "^5.40.0",
    "ioredis": "^5.6.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.3"
  }
}
