generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  VIEWER
  ADMIN
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         UserRole   @default(VIEWER)
  disabledAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  sessions     Session[]
  apiKeys      ApiKey[]
  auditLogs    AuditLog[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

/**
 * API keys: secret shown once; only tokenHash (SHA-256) is stored.
 * Scopes: read, enqueue, admin (admin requires owner UserRole.ADMIN and job allow-list checks).
 */
model ApiKey {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String?
  tokenHash       String    @unique
  /// e.g. "read", "enqueue", "admin"
  scopes          String[]
  /// Registered job `name` values this key may touch (read/enqueue/admin per route rules).
  allowedJobTypes String[]
  createdAt       DateTime  @default(now())
  revokedAt       DateTime?
  lastUsedAt      DateTime?
  auditLogs       AuditLog[]

  @@index([userId])
}

/**
 * Append-only record of mutating API actions (admin-visible). Summary is always redacted / non-sensitive.
 */
model AuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  requestId  String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Present when the actor was an API key; cleared if the key row is removed.
  apiKeyId   String?
  apiKey     ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  /// e.g. job.enqueue, job.retry, api_key.create
  action     String
  /// Redacted JSON: job names, ids, target refs — never raw payloads.
  summary    Json
  result     String
  /// Stable machine code on failure, e.g. validation_failed, job_not_found
  errorCode  String?

  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([action])
}
