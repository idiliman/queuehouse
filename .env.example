DATABASE_URL="postgresql://queuehouse:queuehouse@localhost:5432/queuehouse"
REDIS_URL="redis://localhost:6379"
SESSION_SECRET="local-dev-session-secret-change-me"

# Optional: APP_NAMESPACE / QUEUEHOUSE_NAMESPACE (default queuehouse), PORT, CORS_ORIGIN,
# WORKER_SHUTDOWN_GRACE_MS, WORKER_METRICS_PORT (Prometheus scrape on worker when set)
#
# OpenTelemetry traces (optional): set OTEL_EXPORTER_OTLP_ENDPOINT or OTEL_EXPORTER_OTLP_TRACES_ENDPOINT
# on API and worker to export spans and propagate W3C trace context into Bull job data (`traceContext`).
# Use distinct OTEL_SERVICE_NAME per process (e.g. queuehouse-api / queuehouse-worker).
# Docker / Compose / prod checklist: see DEPLOY.md (migrations and bootstrap are explicit; they do not run on API startup).

# First admin (only when the database has zero users):
# cd packages/db && bun run bootstrap -- --email you@example.com --password '...'
# Or set BOOTSTRAP_ADMIN_EMAIL and BOOTSTRAP_ADMIN_PASSWORD and run `bun run bootstrap` in packages/db.
# In Docker: docker run --rm -e DATABASE_URL ... queuehouse bootstrap -- --email ... --password '...'
#
# Production browser clients: comma-separated origins (dev defaults to http://localhost:5173).
# CORS_ORIGIN="https://app.example.com"
